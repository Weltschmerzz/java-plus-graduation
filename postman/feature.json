		{
			"name": "Find location events",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200 OK\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"const events = pm.response.json();\r",
							"pm.test(\"At least one event found\", function () {\r",
							"    pm.expect(events).to.be.an('array');\r",
							"    pm.expect(events.length).to.be.at.least(1);\r",
							"});\r",
							"\r",
							"pm.test(\"Found event matches\", function () {\r",
							"    const event = events[0];\r",
							"    pm.expect(event.title).to.include(\"Событие рядом\");\r",
							"    pm.expect(event.annotation).to.include(\"Тест геопоиска\");\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
